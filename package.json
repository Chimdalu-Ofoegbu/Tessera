{
  "name": "tessera",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/gen-snapshot.mjs && vite build",
    "gen:snapshot": "node scripts/gen-snapshot.mjs --live",
    "preview": "vite preview",
    "typecheck": "tsc",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@fontsource-variable/archivo": "^5.2.8",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@tanstack/react-query": "^5.101.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.185.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/three": "^0.185.0",
    "@vercel/node": "^5.8.22",
    "@vitejs/plugin-react-swc": "^4.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ]
  }
